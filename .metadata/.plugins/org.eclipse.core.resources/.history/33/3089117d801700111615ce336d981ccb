/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_USART2_UART_Init();
  MX_TIM2_Init();
  /* USER CODE BEGIN 2 */
  HAL_TIM_Base_Start_IT(&htim2);
  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  	{
  // ================== CONTADOR J1 (PC0 a PC3) ================================
  			if (activar_conteo_J1)
  			{
  				activar_conteo_J1 = 0;

  				if (estado_J1 == 0x00)
  				{
  					estado_J1 = 0x01;
  				}
  				else
  				{
  					estado_J1 <<= 1; //Desplazo el 1 para encender los leds
  				}

  				if (estado_J1 > 0x08)
  				{
  					estado_J1 = 0x0F;
  					habilitar_jugadores = 0;
  				}
  			}

  			// Actualizar LEDs J1
  			HAL_GPIO_WritePin(ledJ1_1_GPIO_Port, ledJ1_1_Pin, (estado_J1 & 0x01) ? GPIO_PIN_SET : GPIO_PIN_RESET);
  			HAL_GPIO_WritePin(ledJ1_2_GPIO_Port, ledJ1_2_Pin, (estado_J1 & 0x02) ? GPIO_PIN_SET : GPIO_PIN_RESET);
  			HAL_GPIO_WritePin(ledJ1_3_GPIO_Port, ledJ1_3_Pin, (estado_J1 & 0x04) ? GPIO_PIN_SET : GPIO_PIN_RESET);
  			HAL_GPIO_WritePin(ledJ1_4_GPIO_Port, ledJ1_4_Pin, (estado_J1 & 0x08) ? GPIO_PIN_SET : GPIO_PIN_RESET);

  			if (activar_conteo_J2)
  			{
  				activar_conteo_J2 = 0;

  				if (estado_J2 == 0x00)
  				{
  					estado_J2 = 0x01;
  				}
  				else
  				{
  					estado_J2 <<= 1; //Desplazo el 1 para encender los leds
  				}

  				if (estado_J2 > 0x08)
  				{
  					estado_J2 = 0x0F;
  					habilitar_jugadores = 0;
  				}
  			}

  			// Actualizar LEDs J1
  			HAL_GPIO_WritePin(ledJ2_1_GPIO_Port, ledJ2_1_Pin, (estado_J2 & 0x01) ? GPIO_PIN_SET : GPIO_PIN_RESET);
  			HAL_GPIO_WritePin(ledJ2_2_GPIO_Port, ledJ2_2_Pin, (estado_J2 & 0x02) ? GPIO_PIN_SET : GPIO_PIN_RESET);
  			HAL_GPIO_WritePin(ledJ2_3_GPIO_Port, ledJ2_3_Pin, (estado_J2 & 0x04) ? GPIO_PIN_SET : GPIO_PIN_RESET);
  			HAL_GPIO_WritePin(ledJ2_4_GPIO_Port, ledJ2_4_Pin, (estado_J2 & 0x08) ? GPIO_PIN_SET : GPIO_PIN_RESET);



    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
  }
  /* USER CODE END 3 */
}

