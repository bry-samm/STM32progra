/* USER CODE BEGIN 4 */

void HAL_TIM_PeriodElapsedCallback(TIM_HandleTypeDef *htim)
{
    if (htim->Instance == TIM2)
    {
    	if (activar_conteo)
    		{
    			display_show(contador_mostrar_dis);//Función que me permite ir con un puntero entre el arreglo de la libreria
    			//reset = 1;
    			if (contador_mostrar_dis > 0)
    			{
    				contador_mostrar_dis--; //Realizo la cuenta regresiva
    			}
    			else
    			{
    				//Coloco valores a variables y activo banderas empleadas en el main
    				activar_conteo = 0;
    				habilitar_jugadores = 1;
    				//reset = 0;
    				estado_J1 = 0;
    				estado_J2 = 0;
    			}
    		}
    }
}

void HAL_GPIO_EXTI_Callback(uint16_t GPIO_Pin){
	if(GPIO_Pin == pbJ1_Pin){
		if (habilitar_jugadores)
				{
					activar_conteo_J1 = 1; //Habilito bandera para iniciar el conteo de J1
				}
	}
	else if(GPIO_Pin == pbJ2_Pin){
		if (habilitar_jugadores)
				{
					activar_conteo_J2 = 1; //Habilito bandera para iniciar el conteo de J2
				}
	}
	else if (GPIO_Pin == pb_start_Pin){
		if (!activar_conteo && !habilitar_jugadores) //Evita el reinicio del conteo cuando se está ejecutando y cuando los jugadores están jugando
				{
					//Activo las banderas que me sirven para iniciar el conteo
					contador_mostrar_dis = 5;
					activar_conteo = 1;
				}
	}
}



void display_show(uint8_t numero)
{
    if (numero <= 16)
    {
        uint8_t pattern = dig_display[numero];

        HAL_GPIO_WritePin(g_display_GPIO_Port, g_display_Pin, (pattern & 0x01) ? GPIO_PIN_SET : GPIO_PIN_RESET);
        HAL_GPIO_WritePin(f_display_GPIO_Port, f_display_Pin, (pattern & 0x02) ? GPIO_PIN_SET : GPIO_PIN_RESET);
        HAL_GPIO_WritePin(a_display_GPIO_Port, a_display_Pin, (pattern & 0x04) ? GPIO_PIN_SET : GPIO_PIN_RESET);
        HAL_GPIO_WritePin(b_display_GPIO_Port, b_display_Pin, (pattern & 0x08) ? GPIO_PIN_SET : GPIO_PIN_RESET);
        HAL_GPIO_WritePin(c_display_GPIO_Port, c_display_Pin, (pattern & 0x10) ? GPIO_PIN_SET : GPIO_PIN_RESET);
        HAL_GPIO_WritePin(d_display_GPIO_Port, d_display_Pin, (pattern & 0x20) ? GPIO_PIN_SET : GPIO_PIN_RESET);
        HAL_GPIO_WritePin(e_display_GPIO_Port, e_display_Pin, (pattern & 0x40) ? GPIO_PIN_SET : GPIO_PIN_RESET);
    }
}

